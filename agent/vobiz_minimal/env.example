# --- AI providers ---
# Required for LLM, STT, TTS in the default bot
OPENAI_API_KEY=

# Optional alternative STT provider (recommended for lower latency than OpenAI Whisper)
DEEPGRAM_API_KEY=


# --- Vobiz account ---
# Required
VOBIZ_AUTH_ID=
VOBIZ_AUTH_TOKEN=

# The Vobiz number outbound calls are placed FROM (caller-id). Used by /start
# when "from_number" is not in the request body.
VOBIZ_PHONE_NUMBER=


# --- Vobiz wire format ---
# Must match what server.py advertises in <Stream contentType> and what
# bot.py passes to VobizFrameSerializer.InputParams. The serializer also
# re-negotiates from Vobiz's `start` event at runtime if these disagree.
# Allowed encodings:  audio/x-mulaw | audio/x-l16
# Allowed rates (Hz): 8000 | 16000  (24000 is in the protocol but not
# reliably available on all regions — Vobiz silently refuses the WS upgrade)
VOBIZ_ENCODING=audio/x-mulaw
VOBIZ_SAMPLE_RATE=8000

# L16 byte order on the wire. RFC 2586 and the Vobiz docs say "be" (network
# byte order / big-endian), but some Vobiz accounts empirically transport
# L16 as little-endian — if you see media frames arrive at the right size
# but STT produces no transcripts when VOBIZ_ENCODING=audio/x-l16, set this
# to "le". Ignored for audio/x-mulaw.
VOBIZ_L16_ENDIAN=le


# --- Deployment ---
# local | production
ENV=local

# Required for ngrok / cloud deployments — the public https:// URL where
# Vobiz reaches your /answer endpoint.
# Example: PUBLIC_URL=https://abc123.ngrok-free.app
PUBLIC_URL=

# Only required when ENV=production. The public wss:// URL where your bot
# is hosted (e.g. a Pipecat Cloud agent endpoint or your own deployment).
VOBIZ_PROD_WS_URL=


# --- Human-transfer flow ---
# Required if you use /transfer-to-human or /initiate-transfer. No default
# is hardcoded; the server returns HTTP 500 if this is unset and a transfer
# is attempted.
TRANSFER_AGENT_NUMBER=

# Number dialed by /test-inbound for the two-phone verification flow.
# Optional; falls back to TRANSFER_AGENT_NUMBER if not set.
TEST_DIAL_NUMBER=


# --- Recording (optional) ---
# Set to "false" to disable recording. Defaults to "true".
ENABLE_RECORDING=true

# Max recording length in seconds. Default 3600 (1 hour).
MAX_RECORDING_LENGTH=3600


# --- Pipecat Cloud (only when ENV=production) ---
# Used to construct the production serviceHost query param.
AGENT_NAME=
ORGANIZATION_NAME=
