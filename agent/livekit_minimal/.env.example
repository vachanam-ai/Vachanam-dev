# ==========================================
# LIVEKIT CLOUD CREDENTIALS
# Get these from: https://cloud.livekit.io/
# ==========================================
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIabc123...
LIVEKIT_API_SECRET=secret...

# ==========================================
# AI MODEL KEYS
# ==========================================
OPENAI_API_KEY=sk-...
DEEPGRAM_API_KEY=...

# ==========================================
# VOBIZ SIP TRUNK (from https://console.vobiz.ai/)
# ==========================================
VOBIZ_SIP_DOMAIN=your_sip_domain.sip.vobiz.ai
VOBIZ_USERNAME=your_username
VOBIZ_PASSWORD=your_password
# DID in E.164, e.g. +91...
VOBIZ_OUTBOUND_NUMBER=+91XXXXXXXXXX

# ==========================================
# LIVEKIT SIP RESOURCES — trunk IDs from the LiveKit dashboard / API
# (outbound trunk can be created via scripts/create_vobiz_outbound_trunk.py)
# ==========================================
OUTBOUND_TRUNK_ID=ST_...
INBOUND_TRUNK_ID=ST_...
DISPATCH_RULE_ID=SDR_...
