# ── AI ────────────────────────────────────────────────────────────────
SONIOX_API_KEY=                      # Soniox stt-rt-v5 — STT primary when set (console.soniox.com)
SARVAM_API_KEY=                      # Sarvam Saaras v3 — STT fallback when SONIOX_API_KEY empty
OPENAI_API_KEY=
GEMINI_API_KEY=
# TTS — smallest.ai Waves Lightning (replaced Sarvam Bulbul). Get a key at
# app.smallest.ai/dashboard. Used by the agent (TTS) + voice cloning.
SMALLEST_API_KEY=
SMALLEST_MODEL=lightning_v3.1

# ── Telephony (Vobiz Partner API + WebSocket) ─────────────────────────
VOBIZ_DID_NUMBER=
VOBIZ_AUTH_ID=
VOBIZ_AUTH_TOKEN=

# ── LiveKit voice control plane ───────────────────────────────────────
# Required by the backend's outbound-call jobs (15-min reminders, doctor-
# leave cascade rebook). Without these the jobs log a WARNING and no-op.
LIVEKIT_URL=                         # wss://<project>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
OUTBOUND_TRUNK_ID=                   # SIP trunk id for outbound dialing (global fallback)
INBOUND_TRUNK_ID=                    # SIP inbound trunk — backend auto-wires saved DIDs into it (run scripts/setup_livekit_telephony.py)
DISPATCH_RULE_ID=                    # inbound dispatch rule → agent vachanam-agent (informational; routing is by trunk)

# ── Voice agent (LiveKit) ──────────────────────────────────────────────
PUBLIC_URL=                          # Cloudflare Tunnel URL, e.g. https://agent-dev.vachanam.in
RECORDING_ENABLED=false              # TESTING-ONLY override: set true in dev to record calls
MAX_CALL_DURATION_SECONDS=0          # 0 = unlimited; non-zero = wrap call at N seconds (Solo plan)

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────────
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_WABA_ID=
META_WEBHOOK_VERIFY_TOKEN=
META_APP_SECRET=

# ── Google ────────────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_APPLICATION_CREDENTIALS=./google-service-account.json
GOOGLE_CALENDAR_SERVICE_EMAIL=
GOOGLE_SA_JSON_B64=               # production only: base64 of SA JSON (overrides file path)

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://vachanam:localdev123@localhost:5432/vachanam_dev
TEST_DATABASE_URL=postgresql+asyncpg://vachanam:localdev123@localhost:5432/vachanam_test

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRE_HOURS=8
# Fernet key encrypting secrets at rest (per-clinic Vobiz SIP passwords).
# REQUIRED in production. Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# ── OTP verification (signup phone + email) ───────────────────────────
MSG91_AUTH_KEY=                      # SMS provider; empty = code logged only
MSG91_SENDER_ID=VCHNAM
# Email OTP — Resend preferred (HTTP API, reliable from cloud). Used over SMTP
# when set. from-domain (vachanam.in) must be verified in the Resend dashboard.
RESEND_API_KEY=                      # empty = fall back to SMTP, else code logged only
RESEND_FROM=Vachanam <noreply@vachanam.in>
SMTP_HOST=                           # email OTP SMTP fallback; empty = code logged only
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=hello@vachanam.in
OTP_TTL_SECONDS=600
OTP_DEV_ECHO=true                    # dev only; forced OFF when APP_ENV=production

# ── Monitoring / feedback loop + DPDP retention ───────────────────────
TRANSCRIPT_CAPTURE_ENABLED=true      # capture call transcripts (PII, phone-masked) for the feedback loop; false = outcome-only
TRANSCRIPT_RETENTION_DAYS=90         # transcripts NULLed after this; the non-PII outcome row survives
PATIENT_RETENTION_DAYS=730           # erase a patient's PII this many days after their last appointment (DPDP s.8(7))

# ── Rate limiting ─────────────────────────────────────────────────────
RATE_LIMIT_BYPASS_IPS=               # comma-separated trusted IPs (monitoring)
TRUSTED_PROXY_HOPS=2                  # reverse-proxy hops to trust for real client IP (Cloudflare+Render=2; 0 = no proxy)
# SEC #2: shared secret proving a request came through OUR Cloudflare edge. Add a
# Cloudflare Transform Rule (Rules → Transform → Modify Request Header) that sets
# `X-Vachanam-Edge` to this value on every proxied request, and set the same value
# here. When set, CF-Connecting-IP / True-Client-IP are trusted ONLY with the
# matching header — so a client hitting the Render origin directly can't forge
# their IP to evade rate limits or poison the blocklist. Empty = safe fallback to
# the hop-validated XFF logic.
CF_ORIGIN_SECRET=

# ── Cloudflare Turnstile (bot protection on login/signup) ────────────
TURNSTILE_SECRET_KEY=                 # empty = OFF (dev/tests); prod: secret from CF dashboard. Frontend pair: VITE_TURNSTILE_SITE_KEY on Cloudflare Pages.

# ── Payment ───────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_SOLO_ID=
RAZORPAY_PLAN_CLINIC_ID=
RAZORPAY_PLAN_MULTI_ID=

# ── App config ────────────────────────────────────────────────────────
APP_ENV=development
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ADMIN_PHONE=+919XXXXXXXXX
LOG_LEVEL=debug

# ── Watchdog (#306) ───────────────────────────────────────────────────
ALERT_EMAIL=hello@vachanam.in        # change-triggered health alerts (Resend)
FLY_API_TOKEN=                       # lets watchdog auto-restart the voice agent (fly tokens create org)
FLY_AGENT_APP=vachanam-agent
