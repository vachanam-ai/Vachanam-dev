FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential ffmpeg \
 && rm -rf /var/lib/apt/lists/*

# The voice brain is the LiveKit Agents worker. Install its deps plus the shared
# backend deps (SQLAlchemy/redis/google-calendar/structlog) that agent.tools and
# agent.session_state import. The retired Pipecat path's agent/requirements.txt is
# intentionally NOT installed anymore (no HTTP app server deps at runtime).
COPY agent/livekit_minimal/requirements.txt /app/agent/livekit_minimal/requirements.txt
COPY backend/requirements.txt /app/backend/requirements.txt
RUN pip install --no-cache-dir \
      -r /app/agent/livekit_minimal/requirements.txt \
      -r /app/backend/requirements.txt

COPY agent/ /app/agent/
COPY backend/ /app/backend/

# TD-014: drop root. ffmpeg + the worker need no privileged access at runtime.
RUN useradd --create-home --uid 10001 appuser && chown -R appuser /app
USER appuser

ENV PYTHONUNBUFFERED=1

# Bake the inference model weights (Silero VAD + the multilingual semantic
# turn detector) into the image so the FIRST call doesn't pay a runtime
# download. Runs as appuser so the model cache lands in this user's home and is
# readable at runtime. Needs the same env the worker imports (it only resolves
# plugin model files here, no network calls to our APIs).
RUN python -m agent.livekit_minimal.agent download-files

# The real voice brain is the LiveKit Agents worker (agent/livekit_minimal/agent.py).
# It dials OUT to LiveKit Cloud and registers as a worker — it has NO inbound HTTP
# port (the retired Pipecat/Vobiz HTTP app was deleted in iter1). `start` is the
# run-app subcommand exposed by agents.cli.run_app at the module __main__. A
# process-level check (fly.agent.toml) covers liveness — no HTTP endpoint to probe.
CMD ["python", "-m", "agent.livekit_minimal.agent", "start"]
